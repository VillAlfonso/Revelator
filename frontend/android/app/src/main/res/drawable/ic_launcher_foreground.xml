<?xml version="1.0" encoding="utf-8"?>
<!--
  Revelator app icon — foreground layer.
  Adaptive icons: viewport is 108x108, but only the inner 66x66 is
  guaranteed visible (Android crops to circle/squircle/rounded-square).
  We keep all critical detail inside that 66x66 safe-zone (offset ~21 from each edge).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Outer scan ring (filled) — main brand circle -->
    <path
        android:fillColor="#00ff66"
        android:fillType="evenOdd"
        android:pathData="M54,21 a33,33 0 1,1 -0.001,0 Z M54,25 a29,29 0 1,1 -0.001,0 Z" />

    <!-- Inner shadow ring (subtle) -->
    <path
        android:fillColor="#0d8a3c"
        android:fillType="evenOdd"
        android:pathData="M54,28 a25,25 0 1,1 -0.001,0 Z M54,30.5 a22.5,22.5 0 1,1 -0.001,0 Z" />

    <!-- Crosshair tick marks (cardinal points, just outside scan ring) -->
    <path android:fillColor="#00ff66" android:pathData="M53,16 h2 v6 h-2 z" />
    <path android:fillColor="#00ff66" android:pathData="M53,86 h2 v6 h-2 z" />
    <path android:fillColor="#00ff66" android:pathData="M16,53 h6 v2 h-6 z" />
    <path android:fillColor="#00ff66" android:pathData="M86,53 h6 v2 h-6 z" />

    <!-- Illuminati triangle (clipped fingerprint inside) -->
    <group>
        <clip-path android:pathData="M54,32 L78,72 L30,72 Z" />

        <!-- Triangle fill (very dark green) -->
        <path
            android:fillColor="#001005"
            android:pathData="M54,32 L78,72 L30,72 Z" />

        <!-- Fingerprint whorls inside the triangle -->
        <path android:strokeColor="#00ff66" android:strokeWidth="1" android:fillColor="#00000000"
              android:pathData="M 36 65 Q 54 49 72 65" />
        <path android:strokeColor="#00ff66" android:strokeWidth="1" android:fillColor="#00000000"
              android:pathData="M 39 65 Q 54 52 69 65" />
        <path android:strokeColor="#00ff66" android:strokeWidth="1" android:fillColor="#00000000"
              android:pathData="M 42 65 Q 54 55 66 65" />
        <path android:strokeColor="#00ff66" android:strokeWidth="1" android:fillColor="#00000000"
              android:pathData="M 45 65 Q 54 58 63 65" />
        <path android:strokeColor="#00ff66" android:strokeWidth="1" android:fillColor="#00000000"
              android:pathData="M 48 65 Q 54 61 60 65" />

        <!-- Core dot -->
        <path android:fillColor="#00ff66"
              android:pathData="M53,63 a1.4,1.4 0 1,1 -0.001,0 Z" />
    </group>

    <!-- Triangle outline (drawn after clipped group, full stroke visible) -->
    <path
        android:strokeColor="#00ff66"
        android:strokeWidth="1.6"
        android:fillColor="#00000000"
        android:strokeLineJoin="round"
        android:pathData="M54,32 L78,72 L30,72 Z" />

    <!-- Corner brackets — evidence frame -->
    <path
        android:strokeColor="#00ff66"
        android:strokeWidth="1.2"
        android:fillColor="#00000000"
        android:strokeAlpha="0.7"
        android:strokeLineCap="round"
        android:pathData="M22,28 L22,22 L28,22 M80,22 L85,22 L85,28 M85,80 L85,85 L80,85 M28,85 L22,85 L22,80" />
</vector>

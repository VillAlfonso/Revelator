# ForgeGuard Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# LLM Configuration
# ============================================

# Set to "true" for Groq Cloud, "false" for local Ollama
USE_CLOUD_LLM=false

# Groq Cloud (if USE_CLOUD_LLM=true)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Local Ollama (if USE_CLOUD_LLM=false)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ============================================
# YOLO Configuration
# ============================================

# Path to your trained weights (relative or absolute)
YOLO_WEIGHTS_PATH=./weights/best.pt

# Minimum confidence threshold for detections
CONFIDENCE_THRESHOLD=0.25

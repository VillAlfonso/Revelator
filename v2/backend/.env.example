# ── Firebase Admin SDK ──────────────────────────────────────────────
# Path to your Firebase service-account JSON. Create one at:
#   Firebase Console → Project settings → Service accounts → Generate new private key
# Put the file outside source control and point this at it.
FIREBASE_CREDENTIALS_FILE=./firebase-service-account.json

# Your Firebase Storage bucket name (looks like "<project-id>.appspot.com").
FIREBASE_STORAGE_BUCKET=revelator-xxxxx.appspot.com

# ── App / CORS ──────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
APP_NAME=Revelator
APP_VERSION=2.0.0

# Plan limits and pricing
FREE_SCANS_PER_MONTH=10
PRO_SCANS_PER_MONTH=-1
PREMIUM_SCANS_PER_MONTH=-1
PRO_PRICE_USD=5
PREMIUM_PRICE_USD=10

# ── Gemini Vision ───────────────────────────────────────────────────
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash-lite

# ── LLaVA on Hugging Face (Detective + Sherlock tiers) ──────────────
# Leave blank until your fine-tuned Spaces are deployed.
LLAVA_DETECTIVE_URL=
LLAVA_SHERLOCK_URL=
LLAVA_API_KEY=

# ── LLM explanation (Groq) — Premium tier only ──────────────────────
USE_CLOUD_LLM=true
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Local Ollama fallback if Groq disabled
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Stripe (global card payments) ───────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID_PRO=
STRIPE_PRICE_ID_PREMIUM=

# ── PayMongo (Philippines: cards + GCash + Maya) ────────────────────
PAYMONGO_SECRET_KEY=
PAYMONGO_PUBLIC_KEY=
PAYMONGO_WEBHOOK_SECRET=
